{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "// ELECTRON SCRIPTS": "-----------------------------------------",
    "ts:electron": "tsc -p electron/tsconfig.json && echo '{\"type\":\"commonjs\"}' > dist-electron/package.json",
    "electron:dev": "npm run ts:electron && concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\""
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@livekit/components-react": "^2.9.17",
    "@livekit/components-styles": "^1.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.10",
    "framer-motion": "^12.23.24",
    "gsap": "^3.14.2",
    "livekit-client": "^2.16.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.554.0",
    "node-wifi": "^2.0.16",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "tailwindcss": "^4.1.17",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/gsap": "^1.20.2",
    "@types/node": "^24.10.0",
    "@types/node-wifi": "^2.0.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "wait-on": "^9.0.3"
  }
}
